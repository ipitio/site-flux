---
export interface Props {
  inverted?: boolean;
  items: ReadonlyArray<{
    label: string;
    value: string;
  }>;
}

const { inverted = false, items }: Props = Astro.props;
---

<div class="grid gap-3 sm:grid-cols-3">
  {
    items.map((item, index) => (
      <div class={`section-fade min-w-0 rounded-[1.75rem] px-4 py-4 backdrop-blur-md ${inverted ? "border border-white/15 bg-white/10 dark:border-white/10 dark:bg-white/5" : "border border-[var(--line)] bg-[rgb(var(--surface-card)/0.82)] shadow-panel"}`} style={`animation-delay: ${index * 80}ms;`}>
        <p class={`min-w-0 max-w-full break-normal text-balance font-display text-[clamp(1.45rem,2.7vw,2.05rem)] uppercase tracking-[0.03em] leading-[0.92] ${inverted ? "text-white" : "text-[var(--ink)]"}`}>
          {item.value}
        </p>
        <p class={`mt-2 text-[0.68rem] font-bold uppercase tracking-[0.24em] ${inverted ? "text-white/80" : "text-[var(--muted)]"}`}>
          {item.label}
        </p>
      </div>
    ))
  }
</div>